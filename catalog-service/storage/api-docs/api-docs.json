{
    "openapi": "3.0.0",
    "info": {
        "title": "Catalog Service API",
        "description": "Catalog Service API — Pilih-Pilih Kamar",
        "version": "1.0.0"
    },
    "servers": [
        {
            "url": "/api/v1"
        }
    ],
    "paths": {
        "/addons": {
            "get": {
                "tags": [
                    "Addons"
                ],
                "summary": "Menampilkan menu tambahan seperti sarapan atau asuransi.",
                "operationId": "64df5aae883786ec485e37f8e4180357",
                "parameters": [
                    {
                        "name": "X-IAE-KEY",
                        "in": "header",
                        "description": "NIM Mahasiswa sebagai API Key",
                        "required": true,
                        "schema": {
                            "type": "string",
                            "example": "102022400306"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Daftar addon berhasil diambil",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "status": {
                                            "type": "string",
                                            "example": "success"
                                        },
                                        "message": {
                                            "type": "string",
                                            "example": "Addons retrieved successfully"
                                        },
                                        "data": {
                                            "type": "array",
                                            "items": {
                                                "type": "object"
                                            }
                                        },
                                        "meta": {
                                            "properties": {
                                                "service_name": {
                                                    "type": "string",
                                                    "example": "Catalog-Service"
                                                },
                                                "api_version": {
                                                    "type": "string",
                                                    "example": "v1"
                                                }
                                            },
                                            "type": "object"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Unauthorized — X-IAE-KEY missing or invalid"
                    }
                },
                "security": [
                    {
                        "ApiKeyAuth": []
                    }
                ]
            }
        },
        "/rooms": {
            "get": {
                "tags": [
                    "Rooms"
                ],
                "summary": "Menampilkan daftar kamar (filter berdasarkan lokasi & tanggal).",
                "operationId": "1b492e14cbdc859a446992c209170929",
                "parameters": [
                    {
                        "name": "X-IAE-KEY",
                        "in": "header",
                        "description": "NIM Mahasiswa sebagai API Key",
                        "required": true,
                        "schema": {
                            "type": "string",
                            "example": "102022400306"
                        }
                    },
                    {
                        "name": "location",
                        "in": "query",
                        "description": "Filter berdasarkan lokasi (contoh: Bali)",
                        "required": false,
                        "schema": {
                            "type": "string"
                        }
                    },
                    {
                        "name": "date",
                        "in": "query",
                        "description": "Filter berdasarkan tanggal ketersediaan (YYYY-MM-DD)",
                        "required": false,
                        "schema": {
                            "type": "string",
                            "format": "date"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Daftar kamar berhasil diambil",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "status": {
                                            "type": "string",
                                            "example": "success"
                                        },
                                        "message": {
                                            "type": "string",
                                            "example": "Rooms retrieved successfully"
                                        },
                                        "data": {
                                            "type": "array",
                                            "items": {
                                                "type": "object"
                                            }
                                        },
                                        "meta": {
                                            "properties": {
                                                "service_name": {
                                                    "type": "string",
                                                    "example": "Catalog-Service"
                                                },
                                                "api_version": {
                                                    "type": "string",
                                                    "example": "v1"
                                                }
                                            },
                                            "type": "object"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Unauthorized — X-IAE-KEY missing or invalid"
                    }
                },
                "security": [
                    {
                        "ApiKeyAuth": []
                    }
                ]
            },
            "post": {
                "tags": [
                    "Rooms"
                ],
                "summary": "Menambahkan kamar baru ke katalog + SOAP audit + RabbitMQ event",
                "description": "Add a new room to the catalog + full enterprise integration.\n\nPOST /api/v1/rooms\n\nThis is the main state-changing endpoint. After saving the room:\n1. Calls SoapAuditService (Modul 2) → gets a receipt number.\n2. Calls RabbitMqPublisherService (Modul 3) → broadcasts the event.\n3. Returns the room data with both integration statuses.",
                "operationId": "0fcc821623ab708a9cd94310cad7971f",
                "parameters": [
                    {
                        "name": "X-IAE-KEY",
                        "in": "header",
                        "description": "NIM Mahasiswa sebagai API Key",
                        "required": true,
                        "schema": {
                            "type": "string",
                            "example": "102022400306"
                        }
                    }
                ],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "name",
                                    "location",
                                    "price"
                                ],
                                "properties": {
                                    "name": {
                                        "type": "string",
                                        "example": "Kamar VIP"
                                    },
                                    "location": {
                                        "type": "string",
                                        "example": "Bandung"
                                    },
                                    "price": {
                                        "type": "number",
                                        "example": 500000
                                    },
                                    "description": {
                                        "type": "string",
                                        "example": "Kamar VIP dengan pemandangan gunung"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "Room created with full integration status",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "status": {
                                            "type": "string",
                                            "example": "success"
                                        },
                                        "message": {
                                            "type": "string",
                                            "example": "Room created and integration completed"
                                        },
                                        "data": {
                                            "type": "object"
                                        },
                                        "meta": {
                                            "properties": {
                                                "service_name": {
                                                    "type": "string",
                                                    "example": "Catalog-Service"
                                                },
                                                "api_version": {
                                                    "type": "string",
                                                    "example": "v1"
                                                }
                                            },
                                            "type": "object"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Unauthorized — X-IAE-KEY missing or invalid"
                    },
                    "422": {
                        "description": "Validation error"
                    }
                },
                "security": [
                    {
                        "ApiKeyAuth": []
                    }
                ]
            }
        },
        "/rooms/{id}": {
            "get": {
                "tags": [
                    "Rooms"
                ],
                "summary": "Membuka detail lengkap satu kamar (foto, fasilitas, deskripsi).",
                "operationId": "6648acdecabaa361b4a002000e0f9c47",
                "parameters": [
                    {
                        "name": "X-IAE-KEY",
                        "in": "header",
                        "description": "NIM Mahasiswa sebagai API Key",
                        "required": true,
                        "schema": {
                            "type": "string",
                            "example": "102022400306"
                        }
                    },
                    {
                        "name": "id",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "string",
                            "format": "uuid"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Detail kamar berhasil diambil",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "status": {
                                            "type": "string",
                                            "example": "success"
                                        },
                                        "message": {
                                            "type": "string",
                                            "example": "Room detail retrieved successfully"
                                        },
                                        "data": {
                                            "type": "object"
                                        },
                                        "meta": {
                                            "properties": {
                                                "service_name": {
                                                    "type": "string",
                                                    "example": "Catalog-Service"
                                                },
                                                "api_version": {
                                                    "type": "string",
                                                    "example": "v1"
                                                }
                                            },
                                            "type": "object"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Unauthorized — X-IAE-KEY missing or invalid"
                    },
                    "404": {
                        "description": "Room not found"
                    }
                },
                "security": [
                    {
                        "ApiKeyAuth": []
                    }
                ]
            }
        },
        "/sso/me": {
            "get": {
                "tags": [
                    "SSO"
                ],
                "summary": "Get the authenticated SSO user profile",
                "description": "Returns the current user's profile, including their local role, after JWT verification.",
                "operationId": "ssoMe",
                "parameters": [
                    {
                        "name": "X-IAE-KEY",
                        "in": "header",
                        "description": "NIM Mahasiswa sebagai API Key",
                        "required": true,
                        "schema": {
                            "type": "string",
                            "example": "102022400306"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Authenticated user profile",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "status": {
                                            "type": "string",
                                            "example": "success"
                                        },
                                        "data": {
                                            "properties": {
                                                "id": {
                                                    "type": "integer",
                                                    "example": 1
                                                },
                                                "name": {
                                                    "type": "string",
                                                    "example": "warga11"
                                                },
                                                "email": {
                                                    "type": "string",
                                                    "example": "warga11@ktp.iae.id"
                                                },
                                                "sso_sub": {
                                                    "type": "string",
                                                    "example": "abc-123-def"
                                                },
                                                "role": {
                                                    "properties": {
                                                        "id": {
                                                            "type": "integer",
                                                            "example": 2
                                                        },
                                                        "name": {
                                                            "type": "string",
                                                            "example": "viewer"
                                                        },
                                                        "display_name": {
                                                            "type": "string",
                                                            "example": "Viewer"
                                                        }
                                                    },
                                                    "type": "object"
                                                }
                                            },
                                            "type": "object"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Unauthorized — missing or invalid Bearer token"
                    }
                },
                "security": [
                    {
                        "ApiKeyAuth": []
                    },
                    {
                        "bearerAuth": []
                    }
                ]
            }
        },
        "/sso/verify": {
            "post": {
                "tags": [
                    "SSO"
                ],
                "summary": "Verify a JWT token and return decoded payload",
                "description": "Accepts a Bearer token, verifies it against the JWKS, and returns the decoded claims. Useful for debugging.",
                "operationId": "ssoVerify",
                "parameters": [
                    {
                        "name": "X-IAE-KEY",
                        "in": "header",
                        "description": "NIM Mahasiswa sebagai API Key",
                        "required": true,
                        "schema": {
                            "type": "string",
                            "example": "102022400306"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Token is valid",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "status": {
                                            "type": "string",
                                            "example": "success"
                                        },
                                        "message": {
                                            "type": "string",
                                            "example": "Token is valid."
                                        },
                                        "payload": {
                                            "type": "object"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Token is invalid or expired"
                    }
                },
                "security": [
                    {
                        "ApiKeyAuth": []
                    },
                    {
                        "bearerAuth": []
                    }
                ]
            }
        }
    },
    "components": {
        "securitySchemes": {
            "ApiKeyAuth": {
                "type": "apiKey",
                "name": "X-IAE-KEY",
                "in": "header"
            },
            "bearerAuth": {
                "type": "http",
                "description": "JWT Bearer token from the central SSO server (Cloud Dosen)",
                "bearerFormat": "JWT",
                "scheme": "bearer"
            }
        }
    },
    "tags": [
        {
            "name": "SSO",
            "description": "Federated SSO authentication endpoints"
        },
        {
            "name": "Addons",
            "description": "Addons"
        },
        {
            "name": "Rooms",
            "description": "Rooms"
        }
    ]
}